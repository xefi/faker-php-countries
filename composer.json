{
  "name": "xefi/faker-php-countries",
  "type": "library",
  "version": "1.0.0",
  "description": "Faker extension to manipulate countries",
  "keywords": [
    "faker",
    "data",
    "seeding",
    "fixtures"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Gaël Botton"
    },
    {
      "name": "Martin Soenen"
    }
  ],
  "require": {
    "php": ">=8.3 <8.6",
    "psr/container": "^2.0",
    "xefi/faker-php": "^1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  },
  "autoload": {
    "psr-4": {
      "Xefi\\Faker\\Countries\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Xefi\\Faker\\Countries\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "faker": {
      "providers": [
        "Xefi\\Faker\\Countries\\CountriesServiceProvider"
      ]
    }
  }
}
